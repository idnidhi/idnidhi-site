---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
import { portfolioProjects } from '../data/portfolio-projects';
---

<BaseLayout title="Portfolio - Nidhi Mehta Interior Design" description="Explore our curated collection of interior design projects spanning residential, commercial, and hospitality spaces.">
	<Navigation />

	<!-- Hero Section -->
	<section class="pt-32 pb-16 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-7xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				<span class="bg-gradient-primary bg-clip-text text-transparent">Our</span> Work
			</h1>
			<p class="text-lg md:text-xl text-text-light max-w-3xl mx-auto leading-relaxed">
				Every space tells a story. Explore our portfolio of transformative interior design projects that blend artistry with functionality.
			</p>
		</div>
	</section>

	<!-- Filter Section -->
	<section class="py-8 px-4 sticky top-16 md:top-20 z-40 bg-surface/90 backdrop-blur-md border-b border-border">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-wrap justify-center gap-3">
				<button
					class="filter-btn active px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-filter="all"
				>
					All Projects
				</button>
				<button
					class="filter-btn px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-filter="residential"
				>
					Residential
				</button>
				<button
					class="filter-btn px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-filter="commercial"
				>
					Commercial
				</button>
				<button
					class="filter-btn px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-filter="wellness"
				>
					Wellness
				</button>
				<button
					class="filter-btn px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-filter="office"
				>
					Office
				</button>
			</div>
		</div>
	</section>

	<!-- Portfolio Grid -->
	<section class="py-16 px-4 bg-surface">
		<div class="max-w-7xl mx-auto">
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
				{portfolioProjects.map((project) => (
					<a
						href={`/projects/${project.code.toLowerCase()}`}
						class="project-card group relative overflow-hidden bg-gray-100 cursor-pointer transition-all duration-300 block"
						data-category={project.category}
						style="aspect-ratio: 4/5"
					>
						<!-- Project Image -->
						<img
							src={project.coverImage}
							alt={project.title}
							class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
							loading="lazy"
						/>

						<!-- Info Overlay (Always Visible) -->
						<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent">
							<div class="absolute bottom-0 left-0 right-0 p-5">
								<!-- Project Code Badge -->
								<div class="mb-3">
									<span class="inline-block px-3 py-1 bg-primary/90 text-black text-xs font-mono font-semibold tracking-wide">
										{project.code}
									</span>
								</div>

								<!-- Project Title -->
								<h3 class="font-heading text-xl md:text-2xl font-bold text-white mb-2 leading-tight">
									{project.title}
								</h3>

								<!-- Metadata -->
								<div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-300 mb-3">
									<span class="flex items-center gap-1">
										<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
										</svg>
										{project.year}
									</span>
									<span class="flex items-center gap-1">
										<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
										</svg>
										{project.location}
									</span>
									{project.area && (
										<span class="flex items-center gap-1">
											<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
											</svg>
											{project.area}
										</span>
									)}
									<span class="flex items-center gap-1">
										<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
										</svg>
										{project.imageCount} photos
									</span>
								</div>
							</div>
						</div>

						<!-- Hover Detail Overlay -->
						<div class="absolute inset-0 bg-black/95 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
							<div class="p-6 w-full translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
								<span class="inline-block px-3 py-1 bg-primary text-black text-xs font-mono font-semibold tracking-wide mb-3">
									{project.code}
								</span>
								<h3 class="font-heading text-2xl font-bold text-white mb-3">
									{project.title}
								</h3>
								<p class="text-sm text-gray-300 leading-relaxed mb-4">
									{project.description}
								</p>
								<div class="flex items-center justify-between">
									<div class="text-xs text-gray-400">
										<div>{project.location} • {project.year}</div>
										{project.area && <div>{project.area}</div>}
									</div>
									<span class="inline-flex items-center text-primary text-sm font-semibold gap-2">
										View Gallery
										<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
										</svg>
									</span>
								</div>
							</div>
						</div>
					</a>
				))}
			</div>

			<!-- Empty State (hidden by default, shown when no results) -->
			<div id="empty-state" class="hidden text-center py-20">
				<svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
				<p class="text-xl text-text-light">No projects found in this category.</p>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-16 px-4 bg-black border-t border-border text-white">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="font-heading text-3xl md:text-5xl font-bold mb-4">
				Let's Create Your Dream Space
			</h2>
			<p class="text-lg text-text-light mb-8 leading-relaxed">
				Ready to start your interior transformation journey?
			</p>
			<a
				href="mailto:info@idnidhi.com"
				class="btn-glow btn-primary-glow inline-block px-10 py-4 bg-gradient-primary text-black font-medium uppercase tracking-wider text-sm hover:bg-gradient-primary-hover transition-all duration-300 hover:scale-105 cursor-pointer"
			>
				Get In Touch
			</a>
		</div>
	</section>

	<Footer />
</BaseLayout>

<style>
	.filter-btn {
		border-color: #D8BFD8;
		color: #D8BFD8;
		background-color: transparent;
	}

	.filter-btn:hover {
		background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
		color: #000000;
		border-color: transparent;
	}

	.filter-btn.active {
		background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
		color: #000000;
		border-color: transparent;
	}

	.project-card {
		opacity: 1;
		transform: scale(1);
		transition: opacity 300ms ease-in-out, transform 300ms ease-in-out;
	}

	.project-card.hidden-filter {
		opacity: 0;
		transform: scale(0.95);
		pointer-events: none;
		position: absolute;
		visibility: hidden;
	}
</style>

<script>
	// Filter functionality
	const filterButtons = document.querySelectorAll('.filter-btn');
	const projectCards = document.querySelectorAll('.project-card');
	const emptyState = document.getElementById('empty-state');

	filterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const filter = button.getAttribute('data-filter');

			// Update active button
			filterButtons.forEach((btn) => btn.classList.remove('active'));
			button.classList.add('active');

			// Filter projects
			let visibleCount = 0;
			projectCards.forEach((card) => {
				const category = card.getAttribute('data-category');

				if (filter === 'all' || category === filter) {
					card.classList.remove('hidden-filter');
					visibleCount++;
				} else {
					card.classList.add('hidden-filter');
				}
			});

			// Show/hide empty state
			if (visibleCount === 0) {
				emptyState?.classList.remove('hidden');
			} else {
				emptyState?.classList.add('hidden');
			}
		});
	});
</script>
