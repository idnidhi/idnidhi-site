---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Booking Confirmed - Nidhi Mehta Interior Design" description="Your site visit appointment has been confirmed. We'll call you within 24 hours.">
	<Navigation />

	<!-- Hero Section with Success Message -->
	<section id="main-content" class="pt-32 pb-20 px-4 bg-black relative overflow-hidden min-h-screen flex items-center">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />

		<div class="max-w-4xl mx-auto text-center relative z-10">
			<!-- Success Icon -->
			<div class="mb-8 flex justify-center">
				<div class="w-20 h-20 md:w-24 md:h-24 bg-gradient-primary rounded-full flex items-center justify-center shadow-xl">
					<svg class="w-12 h-12 md:w-14 md:h-14 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
					</svg>
				</div>
			</div>

			<!-- Heading -->
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				You're All Set!
			</h1>

			<!-- Subheading -->
			<p class="text-xl md:text-2xl text-primary mb-4 font-medium">
				Your appointment request has been received
			</p>

			<!-- Key Info Banner -->
			<div class="bg-primary/10 border-2 border-primary p-4 mb-8 max-w-2xl mx-auto">
				<p class="text-text font-medium text-base md:text-lg">
					📞 We'll call you within 24 hours to confirm • No office visit required — we come to you!
				</p>
			</div>

			<!-- Main Message Card -->
			<div class="bg-surface border-2 border-border p-8 md:p-10 mb-8 text-left max-w-2xl mx-auto">
				<h2 class="font-heading text-2xl md:text-3xl font-bold text-text mb-6 text-center">
					What Happens Next?
				</h2>

				<div class="space-y-6">
					<!-- Step 1 -->
					<div class="flex items-start gap-4">
						<div class="flex-shrink-0 w-10 h-10 bg-primary/20 border border-primary rounded-full flex items-center justify-center">
							<span class="text-primary font-bold">1</span>
						</div>
						<div>
							<h3 class="font-heading font-semibold text-text mb-1">Expect Our Call Within 24 Hours</h3>
							<p class="text-text-light text-sm">
								We'll call you to confirm your site visit appointment and answer any questions. No need to visit our office — we work from home and come directly to your property.
							</p>
						</div>
					</div>

					<!-- Step 2 -->
					<div class="flex items-start gap-4">
						<div class="flex-shrink-0 w-10 h-10 bg-primary/20 border border-primary rounded-full flex items-center justify-center">
							<span class="text-primary font-bold">2</span>
						</div>
						<div>
							<h3 class="font-heading font-semibold text-text mb-1">Check Your Email</h3>
							<p class="text-text-light text-sm">
								You'll receive a confirmation email with all the details. Be sure to check your spam folder just in case.
							</p>
						</div>
					</div>

					<!-- Step 3 -->
					<div class="flex items-start gap-4">
						<div class="flex-shrink-0 w-10 h-10 bg-primary/20 border border-primary rounded-full flex items-center justify-center">
							<span class="text-primary font-bold">3</span>
						</div>
						<div>
							<h3 class="font-heading font-semibold text-text mb-1">Prepare for Your Consultation</h3>
							<p class="text-text-light text-sm">
								Start gathering inspiration images and think about your budget and timeline.
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- What to Prepare Card -->
			<div class="bg-gradient-primary text-black p-6 md:p-8 mb-10 max-w-2xl mx-auto text-left">
				<h3 class="font-heading text-xl md:text-2xl font-bold mb-4">
					How to Prepare for Your Site Visit
				</h3>
				<ul class="space-y-3 text-sm md:text-base">
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						Save inspiration images from Pinterest, Instagram, or magazines
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						Have a rough budget range in mind
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						List any specific requirements or concerns
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						Think about your ideal timeline for completion
					</li>
				</ul>
			</div>

			<!-- CTA Buttons -->
			<div class="flex flex-col md:flex-row gap-4 justify-center items-center">
				<a
					href="/"
					class="px-8 py-4 bg-surface border-2 border-border text-text font-medium uppercase tracking-wider text-sm hover:border-primary transition-all duration-300 w-full md:w-auto text-center"
				>
					Back to Home
				</a>
				<a
					href="/portfolio"
					class="px-8 py-4 bg-gradient-primary text-black font-medium uppercase tracking-wider text-sm hover:opacity-90 transition-all duration-300 shadow-lg w-full md:w-auto text-center"
				>
					View Our Work
				</a>
			</div>

			<!-- Contact Info -->
			<div class="mt-12 pt-8 border-t border-border">
				<p class="text-text-light mb-4">
					Have questions before your appointment?
				</p>
				<div class="flex justify-center items-center text-sm">
					<a href="mailto:info@idnidhi.com" class="text-primary hover:underline flex items-center gap-2">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						info@idnidhi.com
					</a>
				</div>
			</div>
		</div>
	</section>

	<Footer />
</BaseLayout>
