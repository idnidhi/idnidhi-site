---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Contact - Nidhi Mehta Interior Design" description="Start your interior design journey with transparent pricing. Virtual-first boutique design studio serving Vadodara.">
	<Navigation />

	<!-- Hero Section - Dark (Preserved) -->
	<section class="pt-32 pb-12 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				Let's Create Your <span class="bg-gradient-primary bg-clip-text text-transparent">Dream Space</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light leading-relaxed max-w-3xl mx-auto">
				We come to you — no office visits needed. Simple, transparent pricing with no hidden charges or confusing quotes. What you see is what you pay. Choose the package that fits your budget and how involved you want to be.
			</p>
		</div>
	</section>

	<!-- Pricing Section - Black Theme with White Cards -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-10">
				<h2 class="font-heading text-3xl md:text-5xl font-bold text-text mb-3">
					Choose Your Package
				</h2>
				<p class="text-lg text-text-light max-w-2xl mx-auto">
					Select the level of support that works for you.
				</p>
			</div>

			<!-- Entry Point Package - Featured with Gradient -->
			<div class="mb-10">
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 relative  shadow-lg">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider ">
						Start Here
					</div>
					<div class="grid md:grid-cols-2 gap-6 items-center">
						<div class="text-left">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Site Visit & Assessment</h3>
							<div class="flex items-baseline mb-3">
								<span class="text-4xl md:text-5xl font-bold">₹499</span>
								<span class="ml-2 opacity-80">fully credited back</span>
							</div>
							<p class="opacity-90 text-base">
								We visit your property, take measurements, and understand what you want. No written estimate at this stage.
							</p>
						</div>
						<div>
							<ul class="space-y-2 text-sm md:text-base text-left">
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Property visit in Vadodara (or video tour)
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Professional measurements of your space
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Discuss your needs, style, and budget
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									General feasibility discussion
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>

			<!-- Interactive Package Selector - Unified Card Layout -->
			<div class="max-w-7xl mx-auto">
				<!-- Unified Container with Tabs + Content -->
				<div class="bg-surface/50 border-2 border-border overflow-visible">

					<!-- Package Selection Tabs -->
					<div class="border-b-2 border-border overflow-visible pt-3">
						<!-- Mobile: 2x2 Grid (No Horizontal Scroll) -->
						<div class="grid grid-cols-2 md:hidden overflow-visible">
							<button
								data-package="estimate"
								class="package-tab px-4 py-4 bg-surface border-r border-b border-border text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 active min-h-[88px] flex flex-col items-center justify-center gap-1"
							>
								<div class="text-primary text-xs font-mono">₹2,999</div>
								<div class="text-sm font-semibold">Estimate</div>
								<div class="text-[10px] text-text-muted">Design + PDF</div>
							</button>
							<button
								data-package="plans"
								class="package-tab px-4 py-4 bg-surface border-b border-border text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 min-h-[88px] flex flex-col items-center justify-center gap-1"
							>
								<div class="text-primary text-xs font-mono">₹15K+</div>
								<div class="text-sm font-semibold">Plans</div>
								<div class="text-[10px] text-text-muted">Full drawings</div>
							</button>
							<button
								data-package="partnership"
								class="package-tab px-4 py-4 bg-gradient-primary text-black border-r border-border font-heading text-center hover:shadow-lg transition-all duration-300 relative min-h-[88px] flex flex-col items-center justify-center gap-1"
							>
								<div class="absolute -top-1.5 left-1/2 -translate-x-1/2 px-2 py-0.5 bg-white border border-primary text-[8px] font-bold uppercase tracking-wider">Popular</div>
								<div class="text-xs font-mono opacity-80 pt-1">6-10%</div>
								<div class="text-sm font-semibold">Partnership</div>
								<div class="text-[10px] opacity-80">We guide you</div>
							</button>
							<button
								data-package="turnkey"
								class="package-tab px-4 py-4 bg-surface border-border text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 min-h-[88px] flex flex-col items-center justify-center gap-1"
							>
								<div class="text-primary text-xs font-mono">10-15%</div>
								<div class="text-sm font-semibold">Turnkey</div>
								<div class="text-[10px] text-text-muted">Full service</div>
							</button>
						</div>

						<!-- Desktop: Horizontal Row -->
						<div class="hidden md:grid md:grid-cols-4 overflow-visible">
							<button
								data-package="estimate"
								class="package-tab px-6 py-6 bg-surface border-r-2 border-border text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 active flex flex-col items-center justify-center gap-2"
							>
								<div class="text-primary text-sm font-mono">₹2,999</div>
								<div class="font-semibold text-base">Estimate Package</div>
								<div class="text-xs text-text-muted">Design + PDF estimate</div>
							</button>
							<button
								data-package="plans"
								class="package-tab px-6 py-6 bg-surface border-r-2 border-border text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 flex flex-col items-center justify-center gap-2"
							>
								<div class="text-primary text-sm font-mono">₹15,000+</div>
								<div class="font-semibold text-base">Design Plans</div>
								<div class="text-xs text-text-muted">Complete drawings & renders</div>
							</button>
							<button
								data-package="partnership"
								class="package-tab px-6 py-6 bg-gradient-primary text-black border-r-2 border-primary font-heading text-center hover:shadow-xl transition-all duration-300 relative flex flex-col items-center justify-center gap-2"
							>
								<div class="absolute -top-2 left-1/2 -translate-x-1/2 px-3 py-0.5 bg-white border border-primary text-[10px] font-bold uppercase tracking-wider">Most Popular</div>
								<div class="text-sm font-mono opacity-80 pt-3">6-10%</div>
								<div class="font-semibold text-base">Partnership</div>
								<div class="text-xs opacity-80">We guide, you save</div>
							</button>
							<button
								data-package="turnkey"
								class="package-tab px-6 py-6 bg-surface text-text font-heading text-center hover:bg-surface/80 transition-all duration-300 flex flex-col items-center justify-center gap-2"
							>
								<div class="text-primary text-sm font-mono">10-15%</div>
								<div class="font-semibold text-base">Turnkey</div>
								<div class="text-xs text-text-muted">We do everything</div>
							</button>
						</div>
					</div>

					<!-- Content Area: Package Details -->
					<div class="relative min-h-[400px] md:min-h-[480px] p-6 md:p-8">
					<!-- Estimate Package Content -->
					<div data-package-content="estimate" class="package-content active absolute inset-0 opacity-100 transition-all duration-500">
						<div class="bg-surface p-5 md:p-8 h-full overflow-y-auto">
							<div class="mb-5 md:mb-6">
								<h3 class="font-heading text-xl md:text-3xl font-bold text-text mb-2 md:mb-3">Design + Estimate Document</h3>
								<div class="flex flex-wrap items-baseline gap-2">
									<span class="text-4xl md:text-6xl font-bold text-text">₹2,999</span>
									<span class="text-sm md:text-lg text-text-light">Credited back to any package</span>
								</div>
							</div>

							<div class="grid md:grid-cols-2 gap-6 md:gap-8">
								<div>
									<h4 class="font-heading font-semibold text-text mb-3 text-sm md:text-base">What's Included:</h4>
									<ul class="space-y-2.5 md:space-y-3 text-sm md:text-base text-text">
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Site visit + measurements (if not done)
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											90-minute design consultation
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Mood board & color palette
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Material & furniture recommendations
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											<strong>Complete estimation document (PDF)</strong>
										</li>
									</ul>
								</div>

								<div class="bg-black/30 p-4 md:p-5 rounded-lg border border-border">
									<h4 class="font-heading font-semibold text-text mb-2 text-sm md:text-base">Who This Is For:</h4>
									<p class="text-sm md:text-base text-text-light leading-relaxed">
										You're handy with execution and enjoy being involved in the process. You want professional design direction and a clear budget breakdown, but you'll handle finding workers and managing the day-to-day execution yourself. This gives you full control while ensuring your vision is professionally guided.
									</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Design Plans Content -->
					<div data-package-content="plans" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-surface p-5 md:p-8 h-full overflow-y-auto">
							<div class="mb-5 md:mb-6">
								<h3 class="font-heading text-xl md:text-3xl font-bold text-text mb-2 md:mb-3">Complete Design Plans</h3>
								<div class="flex flex-wrap items-baseline gap-2">
									<span class="text-4xl md:text-6xl font-bold text-text">₹15K+</span>
									<span class="text-sm md:text-lg text-text-light">Per room, varies by size</span>
								</div>
							</div>

							<div class="grid md:grid-cols-2 gap-6 md:gap-8">
								<div>
									<h4 class="font-heading font-semibold text-text mb-3 text-sm md:text-base">What's Included:</h4>
									<ul class="space-y-2.5 md:space-y-3 text-sm md:text-base text-text">
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Detailed drawings with measurements
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											3D renders (2-3 views per room)
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Material specifications & sources
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											All files for your carpenter
										</li>
									</ul>
								</div>

								<div class="bg-black/30 p-4 md:p-5 rounded-lg border border-border">
									<h4 class="font-heading font-semibold text-text mb-2 text-sm md:text-base">Who This Is For:</h4>
									<p class="text-sm md:text-base text-text-light leading-relaxed">
										You have your own trusted contractors and want to manage the work yourself. You need professional design plans with all technical details, 3D visualizations to see the final look, and complete documentation your carpenter can follow. You're confident in overseeing execution but want expert design input.
									</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Partnership Content -->
					<div data-package-content="partnership" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-gradient-primary text-black border-2 border-primary p-5 md:p-8 shadow-xl h-full overflow-y-auto relative">
							<div class="absolute -top-2.5 md:-top-3 left-4 md:left-8 px-3 md:px-4 py-0.5 md:py-1 bg-white border-2 border-primary text-black text-[10px] md:text-xs font-bold uppercase tracking-wider ">
								Most Popular
							</div>
							<div class="mb-5 md:mb-6 pt-4 md:pt-2">
								<h3 class="font-heading text-xl md:text-3xl font-bold mb-2 md:mb-3">Design + We Guide You</h3>
								<div class="flex flex-wrap items-baseline gap-2">
									<span class="text-4xl md:text-6xl font-bold">6-10%</span>
									<span class="text-sm md:text-lg opacity-80">Of total project cost</span>
								</div>
							</div>

							<div class="grid md:grid-cols-2 gap-6 md:gap-8">
								<div>
									<h4 class="font-heading font-semibold mb-3 text-sm md:text-base">What's Included:</h4>
									<ul class="space-y-2.5 md:space-y-3 text-sm md:text-base">
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Complete design plans & renders
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Connect you with trusted workers
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Regular site visits & quality checks
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Material sourcing guidance
										</li>
									</ul>
								</div>

								<div class="bg-black/10 p-4 md:p-5 rounded-lg border border-black/30">
									<h4 class="font-heading font-semibold mb-2 text-sm md:text-base">Who This Is For:</h4>
									<p class="text-sm md:text-base opacity-90 leading-relaxed">
										Best of both worlds — professional design and oversight without full turnkey costs. You'll pay workers directly and stay involved, while we guide you on hiring, materials, and quality.
									</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Turnkey Content -->
					<div data-package-content="turnkey" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-surface p-5 md:p-8 h-full overflow-y-auto">
							<div class="mb-5 md:mb-6">
								<h3 class="font-heading text-xl md:text-3xl font-bold text-text mb-2 md:mb-3">Full Service - We Do Everything</h3>
								<div class="flex flex-wrap items-baseline gap-2">
									<span class="text-4xl md:text-6xl font-bold text-text">10-15%</span>
									<span class="text-sm md:text-lg text-text-light">Of total project cost</span>
								</div>
							</div>

							<div class="grid md:grid-cols-2 gap-6 md:gap-8">
								<div>
									<h4 class="font-heading font-semibold text-text mb-3 text-sm md:text-base">What's Included:</h4>
									<ul class="space-y-2.5 md:space-y-3 text-sm md:text-base text-text">
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Everything from start to finish
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											We find and manage all workers
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Daily progress updates
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											We buy all materials for you
										</li>
										<li class="flex items-start">
											<svg class="w-5 h-5 md:w-6 md:h-6 text-primary mr-2 md:mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
											</svg>
											Guaranteed completion date
										</li>
									</ul>
								</div>

								<div class="bg-black/30 p-4 md:p-5 rounded-lg border border-border">
									<h4 class="font-heading font-semibold text-text mb-2 text-sm md:text-base">Who This Is For:</h4>
									<p class="text-sm md:text-base text-text-light leading-relaxed">
										Your time is valuable and you prefer to focus on your work or family rather than managing construction. You want a single point of contact who handles everything — from design to handover. You'll approve the plan, and we'll deliver your dream space with guaranteed timelines and daily updates.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
