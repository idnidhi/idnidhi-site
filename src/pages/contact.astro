---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Contact - Nidhi Mehta Interior Design" description="Start your interior design journey with transparent pricing. Virtual-first boutique design studio serving Vadodara.">
	<Navigation />

	<!-- Hero Section - Dark (Preserved) -->
	<section class="pt-32 pb-12 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				Let's Create Your <span class="bg-gradient-primary bg-clip-text text-transparent">Dream Space</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light leading-relaxed max-w-3xl mx-auto">
				We come to you — no office visits needed. Simple, transparent pricing with no hidden charges or confusing quotes. What you see is what you pay. Choose the package that fits your budget and how involved you want to be.
			</p>
		</div>
	</section>

	<!-- Pricing Section - Black Theme with White Cards -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-10">
				<h2 class="font-heading text-3xl md:text-5xl font-bold text-text mb-3">
					Simple, Honest Pricing
				</h2>
				<p class="text-lg text-text-light max-w-2xl mx-auto">
					No hidden charges. No confusing quotes. What you see is what you pay.
				</p>
			</div>

			<!-- Entry Point Package - Featured with Gradient -->
			<div class="mb-10">
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 relative rounded-lg shadow-lg">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider rounded-full">
						Start Here
					</div>
					<div class="grid md:grid-cols-2 gap-6 items-center">
						<div class="text-left">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Site Visit & Assessment</h3>
							<div class="flex items-baseline mb-3">
								<span class="text-4xl md:text-5xl font-bold">₹499</span>
								<span class="ml-2 opacity-80">fully credited back</span>
							</div>
							<p class="opacity-90 text-base">
								We visit your property, take measurements, and understand what you want. No written estimate at this stage.
							</p>
						</div>
						<div>
							<ul class="space-y-2 text-sm md:text-base text-left">
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Property visit in Vadodara (or video tour)
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Professional measurements of your space
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Discuss your needs, style, and budget
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									General feasibility discussion
								</li>
							</ul>
							<a href="#booking" class="inline-block mt-4 px-6 py-3 bg-black text-white font-medium uppercase tracking-wider text-sm hover:bg-gray-900 transition-all duration-300 cursor-pointer rounded shadow-md">
								Book Site Visit
							</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Interactive Package Selector - Tab Based -->
			<div class="max-w-6xl mx-auto">
				<!-- Package Tabs - Horizontal scroll on mobile, grid on desktop -->
				<div class="mb-8">
					<div class="flex md:grid md:grid-cols-4 gap-3 overflow-x-auto md:overflow-visible pb-2 md:pb-0 scrollbar-hide">
						<button
							data-package="estimate"
							class="package-tab flex-shrink-0 px-6 py-4 bg-surface border-2 border-border text-text font-heading font-semibold text-base md:text-lg rounded-lg hover:border-primary transition-all duration-300 whitespace-nowrap active"
						>
							<div class="text-primary text-sm font-mono mb-1">₹2,999</div>
							Estimate Package
						</button>
						<button
							data-package="plans"
							class="package-tab flex-shrink-0 px-6 py-4 bg-surface border-2 border-border text-text font-heading font-semibold text-base md:text-lg rounded-lg hover:border-primary transition-all duration-300 whitespace-nowrap"
						>
							<div class="text-primary text-sm font-mono mb-1">₹15,000+</div>
							Design Plans
						</button>
						<button
							data-package="partnership"
							class="package-tab flex-shrink-0 px-6 py-4 bg-gradient-primary text-black border-2 border-primary font-heading font-semibold text-base md:text-lg rounded-lg hover:shadow-xl transition-all duration-300 whitespace-nowrap relative"
						>
							<div class="absolute -top-2 left-1/2 -translate-x-1/2 px-2 py-0.5 bg-white border border-primary text-[10px] font-bold uppercase tracking-wider rounded-full">Popular</div>
							<div class="text-sm font-mono mb-1 opacity-80 pt-1">6-10%</div>
							Partnership
						</button>
						<button
							data-package="turnkey"
							class="package-tab flex-shrink-0 px-6 py-4 bg-surface border-2 border-border text-text font-heading font-semibold text-base md:text-lg rounded-lg hover:border-primary transition-all duration-300 whitespace-nowrap"
						>
							<div class="text-primary text-sm font-mono mb-1">10-15%</div>
							Turnkey
						</button>
					</div>
				</div>

				<!-- Package Content - Shows selected package details -->
				<div class="relative min-h-[450px]">
					<!-- Estimate Package Content -->
					<div data-package-content="estimate" class="package-content active absolute inset-0 opacity-100 transition-all duration-500">
						<div class="bg-white border-2 border-primary p-8 rounded-lg shadow-xl">
							<div class="mb-6">
								<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-3">Design + Estimate Document</h3>
								<div class="flex items-baseline mb-2">
									<span class="text-5xl md:text-6xl font-bold text-black">₹2,999</span>
									<span class="ml-3 text-lg text-gray-600">Credited back to any package</span>
								</div>
								<p class="text-base text-black mt-4 bg-gray-50 p-3 rounded border-l-4 border-primary">
									<strong>Perfect for:</strong> DIY execution with professional guidance
								</p>
							</div>

							<ul class="space-y-3 text-base text-black mb-8">
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Site visit + measurements (if not done)
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									90-minute design consultation
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Mood board & color palette
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Material & furniture recommendations
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									<strong>Complete estimation document (PDF)</strong>
								</li>
							</ul>

							<a href="#booking" class="btn-glow inline-block px-8 py-4 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
								Book This Package
							</a>
						</div>
					</div>

					<!-- Design Plans Content -->
					<div data-package-content="plans" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-white border-2 border-gray-200 p-8 rounded-lg shadow-xl">
							<div class="mb-6">
								<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-3">Complete Design Plans</h3>
								<div class="flex items-baseline mb-2">
									<span class="text-5xl md:text-6xl font-bold text-black">₹15K+</span>
									<span class="ml-3 text-lg text-gray-600">Per room, varies by size</span>
								</div>
								<p class="text-base text-black mt-4 bg-gray-50 p-3 rounded border-l-4 border-primary">
									<strong>Perfect for:</strong> You manage contractors, we give complete plans
								</p>
							</div>

							<ul class="space-y-3 text-base text-black mb-8">
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Detailed drawings with measurements
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									3D renders (2-3 views per room)
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Material specifications & sources
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									All files for your carpenter
								</li>
							</ul>

							<a href="#booking" class="btn-glow inline-block px-8 py-4 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
								Book This Package
							</a>
						</div>
					</div>

					<!-- Partnership Content -->
					<div data-package-content="partnership" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-gradient-primary text-black border-2 border-primary p-8 rounded-lg shadow-xl relative">
							<div class="absolute -top-3 left-8 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider rounded-full">
								Most Popular Choice
							</div>
							<div class="mb-6 pt-2">
								<h3 class="font-heading text-2xl md:text-3xl font-bold mb-3">Design + We Guide You</h3>
								<div class="flex items-baseline mb-2">
									<span class="text-5xl md:text-6xl font-bold">6-10%</span>
									<span class="ml-3 text-lg opacity-80">Of total project cost</span>
								</div>
								<p class="text-base mt-4 bg-white/20 p-3 rounded border-l-4 border-black">
									<strong>Perfect for:</strong> Save money but need expert help
								</p>
							</div>

							<ul class="space-y-3 text-base mb-8">
								<li class="flex items-start">
									<svg class="w-6 h-6 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Everything from design plans
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Connect you with good carpenters
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Regular site visits to check work
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Help buying materials at best prices
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									You pay workers directly (save money!)
								</li>
							</ul>

							<a href="#booking" class="btn-glow btn-primary-glow inline-block px-8 py-4 bg-black text-white font-medium uppercase tracking-wider text-sm hover:bg-gray-900 hover:scale-105 transition-all duration-300 cursor-pointer rounded shadow-md">
								Choose Partnership
							</a>
						</div>
					</div>

					<!-- Turnkey Content -->
					<div data-package-content="turnkey" class="package-content absolute inset-0 opacity-0 pointer-events-none transition-all duration-500">
						<div class="bg-white border-2 border-gray-200 p-8 rounded-lg shadow-xl">
							<div class="mb-6">
								<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-3">Full Service - We Do Everything</h3>
								<div class="flex items-baseline mb-2">
									<span class="text-5xl md:text-6xl font-bold text-black">10-15%</span>
									<span class="ml-3 text-lg text-gray-600">Of total project cost</span>
								</div>
								<p class="text-base text-black mt-4 bg-gray-50 p-3 rounded border-l-4 border-primary">
									<strong>Perfect for:</strong> Busy people with no time to manage
								</p>
							</div>

							<ul class="space-y-3 text-base text-black mb-8">
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Everything from start to finish
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									We find and manage all workers
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Daily progress updates
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									We buy all materials for you
								</li>
								<li class="flex items-start">
									<svg class="w-6 h-6 text-primary mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Guaranteed completion date
								</li>
							</ul>

							<a href="#booking" class="btn-glow inline-block px-8 py-4 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
								Book This Package
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Package Selector Script -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const tabs = document.querySelectorAll('.package-tab');
			const contents = document.querySelectorAll('.package-content');

			tabs.forEach(tab => {
				tab.addEventListener('click', () => {
					const packageName = tab.dataset.package;

					// Remove active from all tabs
					tabs.forEach(t => {
						t.classList.remove('active');
						// Reset non-partnership tabs to default styles
						if (t.dataset.package !== 'partnership') {
							t.classList.remove('border-primary', 'shadow-lg');
							t.classList.add('border-border');
						}
					});

					// Add active to clicked tab
					tab.classList.add('active');
					if (tab.dataset.package !== 'partnership') {
						tab.classList.add('border-primary', 'shadow-lg');
						tab.classList.remove('border-border');
					}

					// Hide all contents
					contents.forEach(content => {
						content.classList.remove('active');
						content.classList.add('opacity-0', 'pointer-events-none');
						content.classList.remove('opacity-100');
					});

					// Show selected content
					const selectedContent = document.querySelector(`[data-package-content="${packageName}"]`);
					if (selectedContent) {
						setTimeout(() => {
							selectedContent.classList.add('active', 'opacity-100');
							selectedContent.classList.remove('opacity-0', 'pointer-events-none');
						}, 50);
					}
				});
			});
		});
	</script>

	<!-- Custom Styles for Package Selector -->
	<style>
		/* Hide scrollbar but keep functionality */
		.scrollbar-hide {
			-ms-overflow-style: none;
			scrollbar-width: none;
		}
		.scrollbar-hide::-webkit-scrollbar {
			display: none;
		}

		/* Active tab state for non-gradient tabs */
		.package-tab.active:not([data-package="partnership"]) {
			border-color: var(--color-primary);
			box-shadow: 0 10px 15px -3px rgba(216, 191, 216, 0.1);
		}

		/* Smooth content transitions */
		.package-content {
			transition: opacity 500ms cubic-bezier(0.4, 0, 0.2, 1);
		}

		/* Mobile: smooth horizontal scrolling */
		@media (max-width: 768px) {
			.package-tab {
				min-width: 160px;
			}
		}
	</style>

	<!-- FAQ & Booking Section - Dark Theme -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 gap-8">
				<!-- FAQ Column -->
				<div>
					<div class="mb-8">
						<h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">
							Common Questions
						</h2>
						<p class="text-lg text-text-light">
							Everything you want to know before we start.
						</p>
					</div>

					<div class="space-y-3">
						<!-- FAQ 1 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Do you visit for free to see my home?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									We charge ₹2,999 for the first visit because we take it seriously. In that 90 minutes, we'll give you real design ideas, color suggestions, and a clear plan — not just a quick look around.
								</p>
								<p>
									The best part? If you choose any design package after, this ₹2,999 gets adjusted in your total cost. So it's basically free if you work with us.
								</p>
							</div>
						</details>

						<!-- FAQ 2 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Why don't you have an office?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
