---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Contact - Nidhi Mehta Interior Design" description="Start your interior design journey with transparent pricing. Virtual-first boutique design studio serving Vadodara.">
	<Navigation />

	<!-- Hero Section - Dark (Preserved) -->
	<section class="pt-32 pb-12 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				Let's Create Your <span class="bg-gradient-primary bg-clip-text text-transparent">Dream Space</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light leading-relaxed max-w-3xl mx-auto">
				We come to you — no office visits needed. Simple, transparent pricing with no hidden charges or confusing quotes. What you see is what you pay. Choose the package that fits your budget and how involved you want to be.
			</p>
		</div>
	</section>

	<!-- Pricing Section - Black Theme with Portfolio-Style Filters -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-10">
				<h2 class="font-heading text-3xl md:text-5xl font-bold text-text mb-3">
					Simple, Honest Pricing
				</h2>
				<p class="text-lg text-text-light max-w-2xl mx-auto">
					No hidden charges. No confusing quotes. What you see is what you pay.
				</p>
			</div>

			<!-- Entry Point Package - Featured with Gradient -->
			<div class="mb-10">
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 relative shadow-lg">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider">
						Start Here
					</div>
					<div class="grid md:grid-cols-2 gap-6 items-center">
						<div class="text-left">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Site Visit & Assessment</h3>
							<div class="flex items-baseline mb-3">
								<span class="text-4xl md:text-5xl font-bold">₹499</span>
								<span class="ml-2 opacity-80">fully credited back</span>
							</div>
							<p class="opacity-90 text-base">
								We visit your property, take measurements, and understand what you want. No written estimate at this stage.
							</p>
						</div>
						<div>
							<ul class="space-y-2 text-sm md:text-base text-left">
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Property visit in Vadodara (or video tour)
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Professional measurements of your space
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Discuss your needs, style, and budget
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									General feasibility discussion
								</li>
							</ul>
							<a href="#booking" class="inline-block mt-4 px-6 py-3 bg-black text-white font-medium uppercase tracking-wider text-sm hover:bg-gray-900 transition-all duration-300 cursor-pointer shadow-md">
								Book Site Visit
							</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Package Filter Buttons (Portfolio Style) -->
			<div class="flex flex-wrap justify-center gap-3 mb-8">
				<button
					class="package-filter active px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-package="estimate"
				>
					Estimate
				</button>
				<button
					class="package-filter px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-package="plans"
				>
					Design Plans
				</button>
				<button
					class="package-filter px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer relative"
					data-package="partnership"
				>
					<span class="absolute -top-2 left-1/2 -translate-x-1/2 px-2 py-0.5 bg-primary text-black text-[8px] font-bold uppercase tracking-wider whitespace-nowrap">Popular</span>
					Partnership
				</button>
				<button
					class="package-filter px-6 py-2 text-sm uppercase tracking-wider font-medium border-2 transition-all duration-300 cursor-pointer"
					data-package="turnkey"
				>
					Turnkey
				</button>
			</div>

			<!-- Package Cards (No Overlapping) -->
			<div class="max-w-5xl mx-auto">
				<!-- Estimate Package -->
				<div data-package-card="estimate" class="package-card">
					<div class="bg-white border-2 border-primary p-6 md:p-8 shadow-xl">
						<div class="mb-4 md:mb-5">
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Design + Estimate Document</h3>
							<div class="flex flex-wrap items-baseline gap-2 mb-2">
								<span class="text-4xl md:text-5xl font-bold text-black">₹2,999</span>
								<span class="text-sm md:text-base text-gray-600">Credited back to any package</span>
							</div>
							<p class="text-sm md:text-base text-gray-700 bg-gray-50 p-3 border-l-4 border-primary">
								<strong>Perfect for:</strong> DIY execution with professional guidance
							</p>
						</div>

						<div class="space-y-2 text-sm md:text-base text-black mb-5">
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Site visit + measurements
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								90-minute design consultation
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Mood board & color palette
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Material & furniture recommendations
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								<strong>Complete estimation document (PDF)</strong>
							</div>
						</div>

						<a href="#booking" class="inline-block px-6 md:px-8 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-xs md:text-sm hover:bg-primary hover:text-black transition-all duration-300 cursor-pointer">
							Book This Package
						</a>
					</div>
				</div>

				<!-- Design Plans Package -->
				<div data-package-card="plans" class="package-card hidden">
					<div class="bg-white border-2 border-gray-200 p-6 md:p-8 shadow-xl">
						<div class="mb-4 md:mb-5">
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Complete Design Plans</h3>
							<div class="flex flex-wrap items-baseline gap-2 mb-2">
								<span class="text-4xl md:text-5xl font-bold text-black">₹15K+</span>
								<span class="text-sm md:text-base text-gray-600">Per room, varies by size</span>
							</div>
							<p class="text-sm md:text-base text-gray-700 bg-gray-50 p-3 border-l-4 border-primary">
								<strong>Perfect for:</strong> You manage contractors, we give complete plans
							</p>
						</div>

						<div class="space-y-2 text-sm md:text-base text-black mb-5">
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Detailed drawings with measurements
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								3D renders (2-3 views per room)
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Material specifications & sources
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								All files for your carpenter
							</div>
						</div>

						<a href="#booking" class="inline-block px-6 md:px-8 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-xs md:text-sm hover:bg-primary hover:text-black transition-all duration-300 cursor-pointer">
							Book This Package
						</a>
					</div>
				</div>

				<!-- Partnership Package -->
				<div data-package-card="partnership" class="package-card hidden">
					<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 shadow-xl relative">
						<div class="absolute -top-3 left-4 md:left-8 px-3 md:px-4 py-1 bg-white border-2 border-primary text-black text-[10px] md:text-xs font-bold uppercase tracking-wider">
							Most Popular
						</div>
						<div class="mb-4 md:mb-5 pt-2">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Design + We Guide You</h3>
							<div class="flex flex-wrap items-baseline gap-2 mb-2">
								<span class="text-4xl md:text-5xl font-bold">6-10%</span>
								<span class="text-sm md:text-base opacity-80">Of total project cost</span>
							</div>
							<p class="text-sm md:text-base bg-white/20 p-3 border-l-4 border-black">
								<strong>Perfect for:</strong> Save money but need expert help
							</p>
						</div>

						<div class="space-y-2 text-sm md:text-base mb-5">
							<div class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Everything from design plans
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Connect you with good carpenters
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Regular site visits to check work
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Help buying materials at best prices
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								You pay workers directly (save money!)
							</div>
						</div>

						<a href="#booking" class="inline-block px-6 md:px-8 py-3 bg-black text-white font-medium uppercase tracking-wider text-xs md:text-sm hover:bg-gray-900 transition-all duration-300 cursor-pointer shadow-md">
							Choose Partnership
						</a>
					</div>
				</div>

				<!-- Turnkey Package -->
				<div data-package-card="turnkey" class="package-card hidden">
					<div class="bg-white border-2 border-gray-200 p-6 md:p-8 shadow-xl">
						<div class="mb-4 md:mb-5">
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Full Service - We Do Everything</h3>
							<div class="flex flex-wrap items-baseline gap-2 mb-2">
								<span class="text-4xl md:text-5xl font-bold text-black">10-15%</span>
								<span class="text-sm md:text-base text-gray-600">Of total project cost</span>
							</div>
							<p class="text-sm md:text-base text-gray-700 bg-gray-50 p-3 border-l-4 border-primary">
								<strong>Perfect for:</strong> Busy people with no time to manage
							</p>
						</div>

						<div class="space-y-2 text-sm md:text-base text-black mb-5">
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Everything from start to finish
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								We find and manage all workers
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Daily progress updates
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								We buy all materials for you
							</div>
							<div class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Guaranteed completion date
							</div>
						</div>

						<a href="#booking" class="inline-block px-6 md:px-8 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-xs md:text-sm hover:bg-primary hover:text-black transition-all duration-300 cursor-pointer">
							Book This Package
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Package Filter Script (Portfolio Style) -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const filterButtons = document.querySelectorAll('.package-filter');
			const packageCards = document.querySelectorAll('.package-card');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const selectedPackage = button.getAttribute('data-package');

					// Update active button
					filterButtons.forEach((btn) => btn.classList.remove('active'));
					button.classList.add('active');

					// Show selected package card
					packageCards.forEach((card) => {
						const cardPackage = card.getAttribute('data-package-card');
						if (cardPackage === selectedPackage) {
							card.classList.remove('hidden');
						} else {
							card.classList.add('hidden');
						}
					});
				});
			});
		});
	</script>

	<!-- Portfolio-Style Filter Buttons CSS -->
	<style>
		.package-filter {
			border-color: #D8BFD8;
			color: #D8BFD8;
			background-color: transparent;
		}

		.package-filter:hover {
			background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
			color: #000000;
			border-color: transparent;
		}

		.package-filter.active {
			background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
			color: #000000;
			border-color: transparent;
		}

		.package-card {
			opacity: 1;
			transform: scale(1);
			transition: opacity 300ms ease-in-out, transform 300ms ease-in-out;
		}

		.package-card.hidden {
			opacity: 0;
			transform: scale(0.98);
			pointer-events: none;
			position: absolute;
			visibility: hidden;
		}
	</style>

	<!-- FAQ & Booking Section - Dark Theme -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 gap-8">
				<!-- FAQ Column -->
				<div>
					<div class="mb-8">
						<h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">
							Common Questions
						</h2>
						<p class="text-lg text-text-light">
							Everything you want to know before we start.
						</p>
					</div>

					<div class="space-y-3">
						<!-- FAQ 1 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Do you visit for free to see my home?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									We charge ₹2,999 for the first visit because we take it seriously. In that 90 minutes, we'll give you real design ideas, color suggestions, and a clear plan — not just a quick look around.
								</p>
								<p>
									The best part? If you choose any design package after, this ₹2,999 gets adjusted in your total cost. So it's basically free if you work with us.
								</p>
							</div>
						</details>

						<!-- FAQ 2 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Why don't you have an office?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									We work from home and come to your place instead. This saves us rent, and we pass those savings to you with lower prices. Plus, we need to see your actual space to design it properly — not just show you pictures in an office.
								</p>
							</div>
						</details>

						<!-- FAQ 3 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Can I upgrade my package later?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									Yes! Many people start with just design ideas or plans, then later ask us to help with the full work. We'll credit what you've already paid toward the bigger package.
								</p>
							</div>
						</details>

						<!-- FAQ 4 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								What does 6-10% mean exactly?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
