	<!-- Package Selector Script with Auto-Shuffle -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const tabs = document.querySelectorAll('.package-tab');
			const contents = document.querySelectorAll('.package-content');
			const packages = ['estimate', 'plans', 'partnership', 'turnkey'];
			let currentIndex = 0;
			let autoplayInterval = null;
			let isPaused = false;

			// Function to switch to a specific package
			function switchToPackage(packageName) {
				// Remove active from all tabs (both mobile and desktop)
				tabs.forEach(t => {
					t.classList.remove('active');
				});

				// Find and activate ALL matching tabs (mobile + desktop)
				const targetTabs = document.querySelectorAll(`[data-package="${packageName}"]`);
				targetTabs.forEach(targetTab => {
					targetTab.classList.add('active');
				});

				// Hide all contents
				contents.forEach(content => {
					content.classList.remove('active');
					content.classList.add('opacity-0', 'pointer-events-none');
					content.classList.remove('opacity-100');
				});

				// Show selected content
				const selectedContent = document.querySelector(`[data-package-content="${packageName}"]`);
				if (selectedContent) {
					setTimeout(() => {
						selectedContent.classList.add('active', 'opacity-100');
						selectedContent.classList.remove('opacity-0', 'pointer-events-none');
					}, 50);
				}

				// Update current index
				currentIndex = packages.indexOf(packageName);
			}

			// Auto-advance to next package
			function nextPackage() {
				currentIndex = (currentIndex + 1) % packages.length;
				switchToPackage(packages[currentIndex]);
			}

			// Start auto-shuffle
			function startAutoplay() {
				if (!autoplayInterval) {
					autoplayInterval = setInterval(() => {
						if (!isPaused) {
							nextPackage();
						}
					}, 5000); // Change every 5 seconds
				}
			}

			// Stop auto-shuffle
			function stopAutoplay() {
				if (autoplayInterval) {
					clearInterval(autoplayInterval);
					autoplayInterval = null;
				}
			}

			// Manual click handling
			tabs.forEach(tab => {
				tab.addEventListener('click', () => {
					stopAutoplay();
					switchToPackage(tab.dataset.package);
					// Restart autoplay after manual interaction
					setTimeout(() => startAutoplay(), 1000);
				});
			});

			// Pause on hover (for entire package selector container)
			const packageSelector = document.querySelector('.bg-surface\\/50.border-2.border-border');
			if (packageSelector) {
				packageSelector.addEventListener('mouseenter', () => {
					isPaused = true;
				});

				packageSelector.addEventListener('mouseleave', () => {
					isPaused = false;
				});
			}

			// Start auto-shuffle on page load
			startAutoplay();
		});
	</script>

