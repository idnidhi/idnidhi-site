---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Contact - Nidhi Mehta Interior Design" description="Start your interior design journey with transparent pricing. Virtual-first boutique design studio serving Vadodara.">
	<Navigation />

	<!-- Hero Section - Dark (Preserved) -->
	<section class="pt-32 pb-12 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				Let's Create Your <span class="bg-gradient-primary bg-clip-text text-transparent">Dream Space</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light leading-relaxed max-w-3xl mx-auto">
				We come to you — no office visits needed. Simple, transparent pricing with no hidden charges or confusing quotes. What you see is what you pay. Choose the package that fits your budget and how involved you want to be.
			</p>
		</div>
	</section>

	<!-- Pricing Section - Black Theme with White Cards -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-10">
				<h2 class="font-heading text-3xl md:text-5xl font-bold text-text mb-3">
					Simple, Honest Pricing
				</h2>
				<p class="text-lg text-text-light max-w-2xl mx-auto">
					No hidden charges. No confusing quotes. What you see is what you pay.
				</p>
			</div>

			<!-- Entry Point Package - Featured with Gradient -->
			<div class="mb-10">
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 relative rounded-lg shadow-lg">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider rounded-full">
						Start Here
					</div>
					<div class="grid md:grid-cols-2 gap-6 items-center">
						<div class="text-left">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Site Visit & Assessment</h3>
							<div class="flex items-baseline mb-3">
								<span class="text-4xl md:text-5xl font-bold">₹499</span>
								<span class="ml-2 opacity-80">fully credited back</span>
							</div>
							<p class="opacity-90 text-base">
								We visit your property, take measurements, and understand what you want. No written estimate at this stage.
							</p>
						</div>
						<div>
							<ul class="space-y-2 text-sm md:text-base text-left">
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Property visit in Vadodara (or video tour)
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Professional measurements of your space
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Discuss your needs, style, and budget
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									General feasibility discussion
								</li>
							</ul>
							<a href="#booking" class="inline-block mt-4 px-6 py-3 bg-black text-white font-medium uppercase tracking-wider text-sm hover:bg-gray-900 transition-all duration-300 cursor-pointer rounded shadow-md">
								Book Site Visit
							</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Main Pricing Cards - 4 Column Full Width -->
			<div class="grid md:grid-cols-4 gap-6 mb-8">
				<!-- Package 1: Design Consultation & Estimate -->
				<div class="bg-white border-2 border-gray-200 hover:border-primary hover:shadow-xl transition-all duration-300 p-6 rounded-lg flex flex-col min-h-[520px]">
					<div class="mb-4">
						<h3 class="font-heading text-xl font-bold text-black mb-3">Design + Estimate Document</h3>
						<div class="flex items-baseline mb-2">
							<span class="text-4xl font-bold text-black">₹2,999</span>
						</div>
						<p class="text-sm text-black font-medium">
							Credited back to any package
						</p>
					</div>

					<p class="text-black mb-4 text-sm">
						<strong>Good for:</strong> DIY execution with professional guidance
					</p>

					<ul class="space-y-2.5 text-sm text-black mb-6 flex-grow">
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Site visit + measurements (if not done)
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							90-minute design consultation
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Mood board & color palette
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Material & furniture recommendations
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							<strong>Complete estimation document (PDF)</strong>
						</li>
					</ul>

					<a href="#booking" class="btn-glow block text-center px-6 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
						Book Now
					</a>
				</div>

				<!-- Package 2: Design Drawings -->
				<div class="bg-white border-2 border-gray-200 hover:border-primary hover:shadow-xl transition-all duration-300 p-6 rounded-lg flex flex-col min-h-[520px]">
					<div class="mb-4">
						<h3 class="font-heading text-xl font-bold text-black mb-3">Complete Design Plans</h3>
						<div class="flex items-baseline mb-2">
							<span class="text-4xl font-bold text-black">₹15K+</span>
						</div>
						<p class="text-sm text-black">
							Per room, varies by size
						</p>
					</div>

					<p class="text-black mb-4 text-sm">
						<strong>Good for:</strong> You manage contractors, we give complete plans
					</p>

					<ul class="space-y-2.5 text-sm text-black mb-6 flex-grow">
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Detailed drawings with measurements
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							3D renders (2-3 views per room)
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Material specifications & sources
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							All files for your carpenter
						</li>
					</ul>

					<a href="#booking" class="btn-glow block text-center px-6 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
						Get Started
					</a>
				</div>

				<!-- Package 3: Design + Partnership (Most Popular) -->
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 relative rounded-lg shadow-lg flex flex-col min-h-[520px]">
					<div class="absolute -top-2.5 left-1/2 -translate-x-1/2 px-3 py-1 bg-white border-2 border-primary text-black text-[10px] font-bold uppercase tracking-wider rounded-full">
						Most Popular
					</div>
					<div class="mb-4 pt-2">
						<h3 class="font-heading text-xl font-bold mb-3">Design + We Guide You</h3>
						<div class="flex items-baseline mb-2">
							<span class="text-4xl font-bold">6-10%</span>
						</div>
						<p class="text-sm opacity-80">
							Of total project cost
						</p>
					</div>

					<p class="mb-4 text-sm opacity-90">
						<strong>Good for:</strong> Save money but need expert help
					</p>

					<ul class="space-y-2.5 text-sm mb-6 flex-grow">
						<li class="flex items-start">
							<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Everything from design plans
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Connect you with good carpenters
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Regular site visits to check work
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Help buying materials at best prices
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							You pay workers directly (save money!)
						</li>
					</ul>

					<a href="#booking" class="btn-glow btn-primary-glow block text-center px-6 py-3 bg-black text-white font-medium uppercase tracking-wider text-sm hover:bg-gray-900 hover:scale-105 transition-all duration-300 cursor-pointer rounded shadow-md">
						Popular Choice
					</a>
				</div>

				<!-- Package 4: Turnkey -->
				<div class="bg-white border-2 border-gray-200 hover:border-primary hover:shadow-xl transition-all duration-300 p-6 rounded-lg flex flex-col min-h-[520px]">
					<div class="mb-4">
						<h3 class="font-heading text-xl font-bold text-black mb-3">Full Service - We Do Everything</h3>
						<div class="flex items-baseline mb-2">
							<span class="text-4xl font-bold text-black">10-15%</span>
						</div>
						<p class="text-sm text-black">
							Of total project cost
						</p>
					</div>

					<p class="text-black mb-4 text-sm">
						<strong>Good for:</strong> Busy people with no time to manage
					</p>

					<ul class="space-y-2.5 text-sm text-black mb-6 flex-grow">
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Everything from start to finish
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							We find and manage all workers
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Daily progress updates
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							We buy all materials for you
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
							</svg>
							Guaranteed completion date
						</li>
					</ul>

					<a href="#booking" class="btn-glow block text-center px-6 py-3 border-2 border-primary text-primary font-medium uppercase tracking-wider text-sm hover:bg-primary hover:text-black hover:scale-105 transition-all duration-300 cursor-pointer rounded">
						Easy Option
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ & Booking Section - Dark Theme -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 gap-8">
				<!-- FAQ Column -->
				<div>
					<div class="mb-8">
						<h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">
							Common Questions
						</h2>
						<p class="text-lg text-text-light">
							Everything you want to know before we start.
						</p>
					</div>

					<div class="space-y-3">
						<!-- FAQ 1 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Do you visit for free to see my home?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									We charge ₹2,999 for the first visit because we take it seriously. In that 90 minutes, we'll give you real design ideas, color suggestions, and a clear plan — not just a quick look around.
								</p>
								<p>
									The best part? If you choose any design package after, this ₹2,999 gets adjusted in your total cost. So it's basically free if you work with us.
								</p>
							</div>
						</details>

						<!-- FAQ 2 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Why don't you have an office?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									We work from home and come to your place instead. This saves us rent, and we pass those savings to you with lower prices. Plus, we need to see your actual space to design it properly — not just show you pictures in an office.
								</p>
							</div>
						</details>

						<!-- FAQ 3 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Can I upgrade my package later?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									Yes! Many people start with just design ideas or plans, then later ask us to help with the full work. We'll credit what you've already paid toward the bigger package.
								</p>
							</div>
						</details>

						<!-- FAQ 4 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								What does 6-10% mean exactly?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									Let's say your total project will cost ₹2 lakhs (for materials, carpenter, electrician, etc.). With our 6-10% partnership package, our fee would be ₹12,000 to ₹20,000.
								</p>
								<p>
									For that, we give you the complete design, help you find good workers, guide you on buying materials, and regularly check the work quality. You handle the workers directly and pay them, which helps you save money.
								</p>
							</div>
						</details>

						<!-- FAQ 5 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								What's NOT included in your packages?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									Our fees are just for the design and our services. The actual cost of materials (wood, tiles, paint), furniture, carpenter's charges, electrician charges — those are separate. We'll tell you exactly how much all of that will cost before we start.
								</p>
							</div>
						</details>

						<!-- FAQ 6 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Can I pay in installments?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									Yes. For bigger projects, we split the payment into parts — some at the start, some when design is ready, some during work, and final payment after everything is done. We'll discuss this when we meet.
								</p>
							</div>
						</details>

						<!-- FAQ 7 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group rounded-lg hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								How do I get started?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									Simple! Just book a time using the form on the right. We'll meet at your place or do a video call, understand what you want, and give you a detailed plan and price.
								</p>
								<p class="text-primary font-medium">
									Want to chat first? Email us at hello@idnidhi.com
								</p>
							</div>
						</details>
					</div>
				</div>

				<!-- Booking Column -->
				<div id="booking">
					<div class="mb-6">
