---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
---

<BaseLayout title="Contact - Nidhi Mehta Interior Design" description="Start your interior design journey with transparent pricing. Virtual-first boutique design studio serving Vadodara.">
	<Navigation />

	<!-- Hero Section - Dark (Preserved) -->
	<section class="pt-32 pb-12 px-4 bg-black relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="#D8BFD8" />
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h1 class="font-heading font-bold text-display-sm md:text-display leading-none tracking-tighter-xl mb-6 text-text">
				Let's Create Your <span class="bg-gradient-primary bg-clip-text text-transparent">Dream Space</span>
			</h1>
			<p class="text-lg md:text-xl text-text-light leading-relaxed max-w-3xl mx-auto">
				We come to you — no office visits needed. Simple, transparent pricing with no hidden charges or confusing quotes. What you see is what you pay. Choose the package that fits your budget and how involved you want to be.
			</p>
		</div>
	</section>

	<!-- Pricing Section - Black Theme -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-10">
				<h2 class="font-heading text-3xl md:text-5xl font-bold text-text mb-3">
					Choose Your Package
				</h2>
				<p class="text-lg text-text-light max-w-2xl mx-auto">
					Select the level of support that works for you.
				</p>
			</div>

			<!-- Mobile-Only: Package Filter Buttons -->
			<div class="md:hidden flex flex-wrap justify-center gap-3 mb-10 px-4">
				<button
					class="package-filter active px-5 py-3 text-[11px] uppercase tracking-widest font-bold border-2 transition-all duration-300 cursor-pointer"
					data-package="estimate"
				>
					Estimate
				</button>
				<button
					class="package-filter px-5 py-3 text-[11px] uppercase tracking-widest font-bold border-2 transition-all duration-300 cursor-pointer"
					data-package="plans"
				>
					Design Plans
				</button>
				<button
					class="package-filter px-5 py-3 text-[11px] uppercase tracking-widest font-bold border-2 transition-all duration-300 cursor-pointer"
					data-package="partnership"
				>
					Partnership
				</button>
				<button
					class="package-filter px-5 py-3 text-[11px] uppercase tracking-widest font-bold border-2 transition-all duration-300 cursor-pointer"
					data-package="turnkey"
				>
					Turnkey
				</button>
			</div>

			<!-- Package Cards Grid -->
			<div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6">
				<!-- Estimate Package -->
				<div data-package-card="estimate" class="package-card">
					<div class="bg-white border-2 border-primary p-6 md:p-7 shadow-xl h-full flex flex-col min-h-[380px] md:min-h-[420px]">
						<div class="mb-5">
							<div class="text-4xl md:text-5xl font-bold text-black mb-3">₹2,999</div>
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Estimate Package</h3>
							<p class="text-sm md:text-base text-gray-600 mb-3">Design + PDF estimate</p>
						</div>
						<div class="text-sm md:text-base text-black bg-gray-50 p-3 leading-relaxed -mx-6 md:-mx-7 mb-5 min-h-[60px] flex items-center">
							<p><strong>Perfect for:</strong> DIY execution with professional guidance</p>
						</div>

						<ul class="space-y-2.5 text-sm md:text-base text-black flex-grow">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Site visit + measurements
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								90-minute design consultation
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Mood board & color palette
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Material recommendations
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Complete estimation PDF
							</li>
						</ul>
					</div>
				</div>

				<!-- Design Plans Package -->
				<div data-package-card="plans" class="package-card">
					<div class="bg-white border-2 border-gray-200 p-6 md:p-7 shadow-xl h-full flex flex-col min-h-[380px] md:min-h-[420px]">
						<div class="mb-5">
							<div class="text-xs uppercase tracking-wider text-gray-500 mb-2 font-medium">Per room</div>
							<div class="text-4xl md:text-5xl font-bold text-black mb-3">₹15,000+</div>
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Design Plans</h3>
							<p class="text-sm md:text-base text-gray-600 mb-3">Complete drawings & renders</p>
						</div>
						<div class="text-sm md:text-base text-black bg-gray-50 p-3 leading-relaxed -mx-6 md:-mx-7 mb-5 min-h-[60px] flex items-center">
							<p><strong>Perfect for:</strong> You manage contractors, we give complete plans</p>
						</div>

						<ul class="space-y-2.5 text-sm md:text-base text-black flex-grow">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Detailed drawings with measurements
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								3D renders (2-3 views per room)
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Material specifications & sources
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								All files for your carpenter
							</li>
						</ul>
					</div>
				</div>

				<!-- Partnership Package -->
				<div data-package-card="partnership" class="package-card">
					<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-7 shadow-xl relative h-full flex flex-col min-h-[380px] md:min-h-[420px]">
						<div class="absolute -top-3 left-4 px-3 py-1 bg-white border-2 border-primary text-black text-[10px] font-bold uppercase tracking-wider">
							Most Popular
						</div>
						<div class="mb-5 pt-3">
							<div class="text-xs uppercase tracking-wider opacity-80 mb-2 font-medium">Of project cost</div>
							<div class="text-4xl md:text-5xl font-bold mb-3">6-10%</div>
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Partnership</h3>
							<p class="text-sm md:text-base mb-3">We guide, you save</p>
						</div>
						<div class="text-sm md:text-base text-black bg-white/30 p-3 leading-relaxed -mx-6 md:-mx-7 mb-5 min-h-[60px] flex items-center">
							<p><strong>Perfect for:</strong> Save money but need expert help</p>
						</div>

						<ul class="space-y-2.5 text-sm md:text-base text-black flex-grow">
							<li class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Everything from design plans
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Connect you with good carpenters
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Regular site visits to check work
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Help buying materials at best prices
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								You pay workers directly
							</li>
						</ul>
					</div>
				</div>

				<!-- Turnkey Package -->
				<div data-package-card="turnkey" class="package-card">
					<div class="bg-white border-2 border-gray-200 p-6 md:p-7 shadow-xl h-full flex flex-col min-h-[380px] md:min-h-[420px]">
						<div class="mb-5">
							<div class="text-xs uppercase tracking-wider text-gray-500 mb-2 font-medium">Of project cost</div>
							<div class="text-4xl md:text-5xl font-bold text-black mb-3">10-15%</div>
							<h3 class="font-heading text-2xl md:text-3xl font-bold text-black mb-2">Turnkey</h3>
							<p class="text-sm md:text-base text-gray-600 mb-3">We do everything</p>
						</div>
						<div class="text-sm md:text-base text-black bg-gray-50 p-3 leading-relaxed -mx-6 md:-mx-7 mb-5 min-h-[60px] flex items-center">
							<p><strong>Perfect for:</strong> Busy people with no time to manage</p>
						</div>

						<ul class="space-y-2.5 text-sm md:text-base text-black flex-grow">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Everything from start to finish
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								We find and manage all workers
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Daily progress updates
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								We buy all materials for you
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Guaranteed completion date
							</li>
						</ul>
					</div>
				</div>
			</div>

			<!-- Entry Point Package - Featured with Gradient -->
			<div class="mt-10">
				<div class="bg-gradient-primary text-black border-2 border-primary p-6 md:p-8 relative shadow-lg">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-white border-2 border-primary text-black text-xs font-bold uppercase tracking-wider">
						Start Here
					</div>
					<div class="grid md:grid-cols-2 gap-6 items-center">
						<div class="text-left">
							<h3 class="font-heading text-2xl md:text-3xl font-bold mb-2">Site Visit & Assessment</h3>
							<div class="flex items-baseline mb-3">
								<span class="text-4xl md:text-5xl font-bold">₹499</span>
								<span class="ml-2 opacity-80">fully credited back</span>
							</div>
							<p class="opacity-90 text-base">
								We visit your property, take measurements, and understand what you want. No written estimate at this stage.
							</p>
						</div>
						<div>
							<ul class="space-y-2 text-sm md:text-base text-left">
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Property visit in Vadodara (or video tour)
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Professional measurements of your space
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									Discuss your needs, style, and budget
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
									</svg>
									General feasibility discussion
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Package Filter Script (Mobile Only) -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const filterButtons = document.querySelectorAll('.package-filter');
			const packageCards = document.querySelectorAll('.package-card');

			function updateCardVisibility() {
				const isMobile = window.innerWidth < 768;

				if (isMobile) {
					// On mobile: hide all cards except the active one
					const activeButton = document.querySelector('.package-filter.active');
					const selectedPackage = activeButton ? activeButton.getAttribute('data-package') : 'estimate';

					packageCards.forEach((card) => {
						const cardPackage = card.getAttribute('data-package-card');
						if (cardPackage === selectedPackage) {
							card.classList.remove('hidden');
						} else {
							card.classList.add('hidden');
						}
					});
				} else {
					// On desktop: show all cards
					packageCards.forEach((card) => {
						card.classList.remove('hidden');
					});
				}
			}

			// Filter button click handlers
			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const selectedPackage = button.getAttribute('data-package');

					// Update active button
					filterButtons.forEach((btn) => btn.classList.remove('active'));
					button.classList.add('active');

					// Update card visibility
					updateCardVisibility();
				});
			});

			// Initial setup
			updateCardVisibility();

			// Handle window resize
			window.addEventListener('resize', updateCardVisibility);
		});
	</script>

	<!-- Portfolio-Style Filter Buttons CSS -->
	<style>
		.package-filter {
			border-color: #D8BFD8;
			color: #D8BFD8;
			background-color: rgba(0, 0, 0, 0.2);
			backdrop-filter: blur(4px);
		}

		.package-filter:hover {
			background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
			color: #000000;
			border-color: #D8BFD8;
			transform: translateY(-1px);
			box-shadow: 0 4px 12px rgba(216, 191, 216, 0.3);
		}

		.package-filter.active {
			background-image: linear-gradient(135deg, #F5E6E8, #D8BFD8, #C0A6B8);
			color: #000000;
			border-color: #D8BFD8;
			box-shadow: 0 2px 8px rgba(216, 191, 216, 0.4);
		}

		.package-filter:active {
			transform: translateY(0);
		}

		/* Hide cards with .hidden class */
		.package-card.hidden {
			display: none;
		}
	</style>

	<!-- FAQ & Booking Section - Dark Theme -->
	<section class="py-12 px-4 bg-black border-t border-border">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 gap-8">
				<!-- FAQ Column -->
				<div>
					<div class="mb-8">
						<h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-3">
							Common Questions
						</h2>
						<p class="text-lg text-text-light">
							Everything you want to know before we start.
						</p>
					</div>

					<div class="space-y-3">
						<!-- FAQ 1 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Do you visit for free to see my home?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
									We charge ₹2,999 for the first visit because we take it seriously. In that 90 minutes, we'll give you real design ideas, color suggestions, and a clear plan — not just a quick look around.
								</p>
								<p>
									The best part? If you choose any design package after, this ₹2,999 gets adjusted in your total cost. So it's basically free if you work with us.
								</p>
							</div>
						</details>

						<!-- FAQ 2 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Why don't you have an office?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									We work from home and come to your place instead. This saves us rent, and we pass those savings to you with lower prices. Plus, we need to see your actual space to design it properly — not just show you pictures in an office.
								</p>
							</div>
						</details>

						<!-- FAQ 3 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								Can I upgrade my package later?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm">
								<p>
									Yes! Many people start with just design ideas or plans, then later ask us to help with the full work. We'll credit what you've already paid toward the bigger package.
								</p>
							</div>
						</details>

						<!-- FAQ 4 -->
						<details class="bg-surface border border-border p-4 cursor-pointer group  hover:border-primary transition-colors">
							<summary class="font-heading text-base md:text-lg font-semibold text-text list-none flex justify-between items-center">
								What does 6-10% mean exactly?
								<svg class="w-5 h-5 text-primary transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
								</svg>
							</summary>
							<div class="mt-3 text-text-light leading-relaxed text-sm space-y-2">
								<p>
