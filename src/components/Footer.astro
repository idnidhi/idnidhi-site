---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface border-t border-border text-text-light py-12 md:py-16">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
			<!-- About -->
			<div>
				<h3 class="font-heading text-2xl font-semibold text-primary mb-4">Nidhi Mehta</h3>
				<p class="text-sm leading-relaxed text-text-muted">
					Creating timeless interior spaces that blend elegance with functionality. Every project is a unique story of transformation.
				</p>
			</div>

			<!-- Quick Links -->
			<div>
				<h4 class="font-heading text-lg font-semibold text-text mb-4">Quick Links</h4>
				<ul class="space-y-2">
					<li><a href="/" class="text-sm hover:text-primary transition-colors cursor-pointer">Home</a></li>
					<li><a href="/portfolio" class="text-sm hover:text-primary transition-colors cursor-pointer">Portfolio</a></li>
					<li><a href="/about" class="text-sm hover:text-primary transition-colors cursor-pointer">About</a></li>
					<li><a href="/contact" class="text-sm hover:text-primary transition-colors cursor-pointer">Contact</a></li>
				</ul>
			</div>

			<!-- Contact Info -->
			<div>
				<h4 class="font-heading text-lg font-semibold text-text mb-4">Get In Touch</h4>
				<ul class="space-y-2 text-sm">
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						<a href="mailto:hello@idnidhi.com" class="hover:text-primary transition-colors">hello@idnidhi.com</a>
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
						</svg>
						<span>Mumbai, India</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="border-t border-border mt-12 pt-8 text-center">
			<p class="text-sm text-text-muted">
				&copy; {currentYear} Nidhi Mehta Interior Design. All rights reserved.
			</p>
		</div>
	</div>
</footer>
