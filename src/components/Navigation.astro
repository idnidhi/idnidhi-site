---
const navItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Portfolio', href: '/portfolio' },
	{ label: 'About', href: '/about' },
	{ label: 'Contact', href: '/contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-md border-b border-border">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16 md:h-20">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity duration-300">
				<img src="/images/logo.png" alt="Nidhi Mehta Interior Design" class="h-10 md:h-12 w-auto" />
				<span class="font-heading text-xl md:text-2xl font-semibold text-primary tracking-tight">Nidhi Mehta</span>
			</a>

			<!-- Desktop Navigation -->
			<ul class="hidden md:flex items-center space-x-8">
				{navItems.map((item) => (
					<li>
						<a
							href={item.href}
							class="text-sm uppercase tracking-wider font-medium text-text-light hover:text-primary transition-colors duration-300 cursor-pointer"
						>
							{item.label}
						</a>
					</li>
				))}
			</ul>

			<!-- Mobile Menu Button -->
			<button
				id="mobile-menu-button"
				class="md:hidden p-2 text-text-light hover:text-primary transition-colors cursor-pointer"
				aria-label="Toggle menu"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile Navigation -->
	<div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface">
		<ul class="px-4 py-4 space-y-3">
			{navItems.map((item) => (
				<li>
					<a
						href={item.href}
						class="block py-2 text-sm uppercase tracking-wider font-medium text-text-light hover:text-primary transition-colors duration-300 cursor-pointer"
					>
						{item.label}
					</a>
				</li>
			))}
		</ul>
	</div>
</nav>

<script>
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');

	mobileMenuButton?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
	});
</script>
